# ─────────────────────────────────────────────────────────────────────────────
# AI Video API — environment configuration
# Copy to `.env`. Every value has a safe default in app/config/settings.py.
# All variables are prefixed AIV_ and read via pydantic-settings.
# ─────────────────────────────────────────────────────────────────────────────

# --- App ---
AIV_ENV=dev                      # dev | staging | prod
AIV_DEBUG=true
AIV_API_HOST=0.0.0.0
AIV_API_PORT=8000
AIV_PUBLIC_BASE_URL=http://localhost:8000   # used to build absolute result/upload URLs

# --- Security ---
AIV_ADMIN_TOKEN=change-me-admin-token-please
AIV_API_KEY_HEADER=X-API-Key
AIV_ADMIN_TOKEN_HEADER=X-Admin-Token
AIV_RATE_LIMIT_PER_MINUTE=120
AIV_MAX_UPLOAD_MB=25
AIV_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
AIV_MAX_IMAGE_PIXELS=50000000    # decompression-bomb guard (~50 MP)

# --- Database ---
# SQLite (default) — file path is relative to AIV_DATA_DIR.
AIV_DATABASE_URL=sqlite+aiosqlite:///./data/aivideo.db
# PostgreSQL (later): postgresql+asyncpg://user:pass@host:5432/aivideo

# --- Redis / Queue ---
AIV_REDIS_URL=redis://localhost:6379/0
AIV_QUEUE_NAME=generation
AIV_JOB_TIMEOUT_SECONDS=1800
AIV_JOB_RESULT_TTL_SECONDS=86400

# --- Storage ---
AIV_DATA_DIR=./data
AIV_UPLOADS_SUBDIR=uploads
AIV_RESULTS_SUBDIR=results
AIV_RESULT_RETENTION_DAYS=30

# --- Config (modes / workflows / models) ---
AIV_CONFIG_DIR=./config
AIV_MODES_SUBDIR=modes
AIV_WORKFLOWS_SUBDIR=workflows
AIV_MODELS_FILE=models.json

# --- Generation backend ---
# local  → in-pod RQ worker drives ComfyUI (API runs ON a RunPod GPU pod)
# runpod → this API only orchestrates; generation runs on a RunPod Serverless
#          endpoint and returns via webhook (API runs on a cheap CPU host, e.g. Selectel)
AIV_GENERATION_BACKEND=local
AIV_RUNPOD_API_KEY=
AIV_RUNPOD_ENDPOINT_ID=
AIV_RUNPOD_BASE_URL=https://api.runpod.ai/v2
AIV_RUNPOD_WEBHOOK_SECRET=change-me-webhook-secret
AIV_RUNPOD_TIMEOUT_SECONDS=30

# --- ComfyUI (only used when AIV_GENERATION_BACKEND=local) ---
AIV_COMFY_HOST=127.0.0.1
AIV_COMFY_PORT=8188
AIV_COMFY_HTTPS=false
AIV_COMFY_POLL_INTERVAL=1.0
AIV_COMFY_TIMEOUT_SECONDS=1800
AIV_COMFY_INPUT_DIR=/workspace/ComfyUI/input
AIV_COMFY_OUTPUT_DIR=/workspace/ComfyUI/output

# --- Callbacks ---
AIV_CALLBACK_MAX_RETRIES=5
AIV_CALLBACK_TIMEOUT_SECONDS=15
AIV_CALLBACK_HMAC_SECRET=change-me-callback-signing-secret

# --- Serverless result delivery (RunPod Serverless only; optional) ---
# If set, generated videos are uploaded to S3/R2 and the job returns a short URL
# instead of inline base64. Works with AWS S3, Cloudflare R2, Backblaze B2.
# AIV_S3_BUCKET=my-results-bucket
# AIV_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# AIV_S3_REGION=auto
# AIV_S3_ACCESS_KEY=
# AIV_S3_SECRET_KEY=
# AIV_S3_PUBLIC_BASE=https://cdn.example.com   # if the bucket is public/CDN-fronted

# --- Logging ---
AIV_LOG_LEVEL=INFO
AIV_LOG_JSON=true
AIV_LOG_DIR=./data/logs
